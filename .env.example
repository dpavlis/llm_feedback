# =============================================================================
# CloverDX LLM Chat - Configuration File
# =============================================================================
# Copy this file to .env and modify as needed.
# All settings have sensible defaults and are optional.
# Environment variables take precedence over this file.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER SETTINGS
# -----------------------------------------------------------------------------
# Port number for the HTTP server
PORT=8000

# Host address to bind to (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# Number of Uvicorn workers (keep at 1 for GPU inference to avoid memory issues)
WORKERS=1

# Enable debug mode (auto-reload, verbose logging)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# MODEL SETTINGS
# -----------------------------------------------------------------------------
# HuggingFace model name or identifier
# Examples:
#   - Qwen/Qwen2.5-Coder-7B-Instruct (default)
#   - meta-llama/Llama-2-7b-chat-hf
#   - mistralai/Mistral-7B-Instruct-v0.2
#   - microsoft/phi-2
MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct

# Local path to model files (overrides MODEL_NAME if set)
# Use this if you have downloaded the model locally
# MODEL_PATH=/path/to/local/model

# -----------------------------------------------------------------------------
# GPU / DEVICE SETTINGS
# -----------------------------------------------------------------------------
# Device to run the model on:
#   - cuda      : Use first available NVIDIA GPU
#   - cuda:0    : Use specific NVIDIA GPU by index
#   - cuda:1    : Use second NVIDIA GPU
#   - mps       : Use Apple Silicon GPU (M1/M2/M3)
#   - cpu       : Use CPU only (slow, but works everywhere)
#   - (empty)   : Auto-detect best available device
MODEL_DEVICE=

# Restrict which CUDA GPUs are visible to the application
# This sets CUDA_VISIBLE_DEVICES before PyTorch initializes
# Examples:
#   - 0         : Only use GPU 0
#   - 1         : Only use GPU 1
#   - 0,1       : Use GPUs 0 and 1
#   - 2,3       : Use GPUs 2 and 3
# Leave empty to use all available GPUs
CUDA_VISIBLE_DEVICES=

# Model precision/quantization:
#   - auto      : Automatic (float16 for GPU, float32 for CPU)
#   - float16   : Half precision (faster, less memory)
#   - bfloat16  : Brain floating point (better for some models)
#   - float32   : Full precision (slower, more memory)
#   - 4bit      : 4-bit quantization (requires bitsandbytes)
#   - 8bit      : 8-bit quantization (requires bitsandbytes)
MODEL_DTYPE=auto

# Load model with 8-bit quantization (reduces memory ~50%, requires bitsandbytes)
LOAD_IN_8BIT=false

# Load model with 4-bit quantization (reduces memory ~75%, requires bitsandbytes)
LOAD_IN_4BIT=false

# -----------------------------------------------------------------------------
# GENERATION SETTINGS
# -----------------------------------------------------------------------------
# Maximum context length (input + output tokens)
MAX_MODEL_LEN=4096

# Maximum tokens to generate per response
MAX_RESPONSE_TOKENS=1024

# Sampling temperature (0.0 = deterministic, 1.0 = default, 2.0 = very random)
TEMPERATURE=0.7

# Top-p (nucleus) sampling - only consider tokens with cumulative probability <= top_p
TOP_P=0.9

# Top-k sampling - only consider the k most likely tokens (0 = disabled)
TOP_K=50

# Repetition penalty (1.0 = none, 1.1-1.5 = moderate, >1.5 = strong)
REPETITION_PENALTY=1.0

# Trust remote code from HuggingFace (required for some models like Qwen)
TRUST_REMOTE_CODE=true

# -----------------------------------------------------------------------------
# SESSION SETTINGS
# -----------------------------------------------------------------------------
# Hours before inactive sessions expire
SESSION_TIMEOUT_HOURS=24

# Name of the session cookie
COOKIE_NAME=llm_session

# Require HTTPS for cookies (set to true in production with HTTPS)
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# STORAGE SETTINGS
# -----------------------------------------------------------------------------
# Directory for conversation logs (relative or absolute path)
DATA_DIR=data/conversations

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
# Application name shown in the UI
APP_NAME=CloverDX LLM Chat

# Optional system prompt prepended to all conversations
# Use \n for newlines
# SYSTEM_PROMPT=You are a helpful coding assistant.
